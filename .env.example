# Copy this file to .env and fill in your values. NEVER commit .env.

# Anthropic Claude API key (required for AI generation; leave blank for offline/manual mode)
ANTHROPIC_API_KEY=

# Model + generation settings (optional)
ANTHROPIC_MODEL=claude-opus-4-8
AI_MAX_TOKENS=8000
AI_MAX_RETRIES=2

# Upload limits
MAX_FILE_MB=25
MAX_TEXT_CHARS_PER_DOC=60000

# Local SQLite path (optional)
# NIS_DB_PATH=data/nis.db
